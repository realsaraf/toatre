# Plotto — Environment Variables (template)
# Copy to .env.local (root), apps/mobile/.env, or apps/web/.env.local as needed.
# Never commit real values.

# --- Supabase ---
# From https://supabase.com/dashboard/project/<id>/settings/api
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only (Edge Functions, Drizzle migrations). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# --- OpenAI (primary LLM + Whisper transcription) ---
OPENAI_API_KEY=

# --- Langfuse (LLM observability) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# --- Sentry ---
SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- PostHog ---
EXPO_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- Twilio Verify (phone number OTP verification) ---
# From https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# From https://console.twilio.com/us1/develop/verify/services
TWILIO_VERIFY_SERVICE_SID=

# --- Expo / EAS ---
EXPO_TOKEN=
