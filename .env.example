# =====================================================================
# Toatre — example environment configuration
# Copy this to web/.env.local for local web dev. Never commit real values.
# Production values live in DigitalOcean App Platform env settings.
# Mobile env values are wired via Codemagic (--dart-define flags).
# =====================================================================

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=replace-me-with-a-32-byte-random-hex

# ---- Firebase Admin (server) ----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Note: include the literal \n line-breaks for the private key on a single line.
FIREBASE_PRIVATE_KEY=

# ---- Firebase Web Client (public, prefixed NEXT_PUBLIC_) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# ---- MongoDB ----
# Co-tenanted in existing Mutqin Atlas cluster. DB name varies per env.
MONGODB_URI=
MONGODB_DB=toatre_dev

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_ESCALATION_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# ---- Langfuse ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Twilio ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_SMS_FROM=

# ---- Resend ----
RESEND_API_KEY=
REMINDER_FROM_EMAIL=Toatre <hello@toatre.com>

# ---- DigitalOcean Spaces (S3-compatible) ----
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=nyc3
SPACES_BUCKET=toatre-dev
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ---- Sentry (web) ----
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=toatre
SENTRY_PROJECT=toatre-web

# ---- PostHog ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =====================================================================
# Mobile-only values (wired via --dart-define in mobile/codemagic.yaml,
# documented here for reference)
# =====================================================================
# API_BASE_URL=http://localhost:3000     # dev: connect to local web; prod: https://toatre.com
# SENTRY_DSN_MOBILE=
# POSTHOG_KEY_MOBILE=
# POSTHOG_HOST_MOBILE=https://us.i.posthog.com
