{
  "name": "plotto",
  "version": "0.0.0",
  "private": true,
  "description": "Plotto — Your life, plotted out. (Proprietary, NDA-protected.)",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:mobile": "pnpm --filter @plotto/mobile dev",
    "dev:web": "pnpm --filter @plotto/web dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "postgres": "^3.4.9",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.0",
      "@types/react-dom": "19.0.0"
    }
  }
}
